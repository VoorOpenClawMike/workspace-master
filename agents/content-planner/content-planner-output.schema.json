{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/content-planner-output.schema.json",
  "title": "Content Planner Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["overview", "calendar", "script_briefings", "notes"],
  "properties": {
    "overview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planning_scope",
        "primary_goal",
        "target_audience",
        "platforms",
        "posting_frequency_per_platform"
      ],
      "properties": {
        "planning_scope": {
          "type": "string",
          "enum": ["7_dagen", "30_dagen", "campagne_specifiek"]
        },
        "primary_goal": {
          "type": "string",
          "enum": ["groei_volgers", "leads", "naamsbekendheid", "engagement"]
        },
        "target_audience": { "type": "string", "minLength": 1 },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "TikTok",
              "YouTube Shorts",
              "Instagram Reels",
              "YouTube",
              "Instagram",
              "X",
              "LinkedIn"
            ]
          }
        },
        "posting_frequency_per_platform": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 21
          }
        }
      }
    },
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date", "timezone", "items"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "default": "Europe/Amsterdam"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "date",
              "platform",
              "time_slot",
              "topic",
              "working_title",
              "format",
              "duration_hint_seconds",
              "target_kpi",
              "script_brief_id"
            ],
            "properties": {
              "id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
              "date": { "type": "string", "format": "date" },
              "platform": {
                "type": "string",
                "enum": [
                  "TikTok",
                  "YouTube Shorts",
                  "Instagram Reels",
                  "YouTube",
                  "Instagram",
                  "X",
                  "LinkedIn"
                ]
              },
              "time_slot": { "type": "string", "enum": ["ochtend", "middag", "avond"] },
              "topic": { "type": "string", "minLength": 1 },
              "working_title": { "type": "string", "minLength": 1 },
              "format": {
                "type": "string",
                "enum": ["educational", "entertainment", "behind_the_scenes", "testimonial", "trend_remix"]
              },
              "duration_hint_seconds": { "type": "integer", "minimum": 5, "maximum": 900 },
              "target_kpi": { "type": "string", "enum": ["views", "saves", "shares", "klikratio"] },
              "script_brief_id": { "type": "string", "pattern": "^SB-[0-9]{3,}$" }
            }
          }
        }
      }
    },
    "script_briefings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["briefs"],
      "properties": {
        "briefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "script_brief_id",
              "linked_content_item_id",
              "objective",
              "core_message",
              "audience_segment",
              "hook_direction",
              "key_points",
              "cta",
              "tone_style",
              "constraints"
            ],
            "properties": {
              "script_brief_id": { "type": "string", "pattern": "^SB-[0-9]{3,}$" },
              "linked_content_item_id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
              "objective": { "type": "string", "minLength": 1 },
              "core_message": { "type": "string", "minLength": 1 },
              "audience_segment": { "type": "string", "minLength": 1 },
              "hook_direction": { "type": "string", "minLength": 1 },
              "key_points": {
                "type": "array",
                "minItems": 1,
                "maxItems": 6,
                "items": { "type": "string", "minLength": 1 }
              },
              "cta": { "type": "string", "minLength": 1 },
              "tone_style": { "type": "string", "minLength": 1 },
              "constraints": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_pillars", "experiments", "risks_or_caveats"],
      "properties": {
        "content_pillars": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "experiments": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risks_or_caveats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$comment": "Cross-reference checks (VID<->SB consistency and uniqueness across arrays) require runtime validation in addition to JSON Schema."
}
