{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/script-writer-output.schema.json",
  "title": "Script Writer Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["scripts"],
  "properties": {
    "scripts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "script_brief_id",
          "linked_content_item_id",
          "platform",
          "estimated_duration_seconds",
          "structure",
          "script",
          "voice_and_style",
          "annotations"
        ],
        "properties": {
          "script_brief_id": {
            "type": "string",
            "pattern": "^SB-[0-9]{3,}$"
          },
          "linked_content_item_id": {
            "type": "string",
            "pattern": "^VID-[0-9]{3,}$"
          },
          "platform": {
            "type": "string",
            "enum": [
              "TikTok",
              "YouTube Shorts",
              "Instagram Reels",
              "YouTube",
              "Instagram",
              "X",
              "LinkedIn"
            ]
          },
          "estimated_duration_seconds": {
            "type": "integer",
            "minimum": 5,
            "maximum": 1200
          },
          "structure": {
            "type": "string",
            "const": "HOOK_BODY_CTA"
          },
          "script": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hook", "body", "cta"],
            "properties": {
              "hook": {
                "type": "object",
                "additionalProperties": false,
                "required": ["text", "notes"],
                "properties": {
                  "text": { "type": "string", "minLength": 1 },
                  "notes": { "type": "string" }
                }
              },
              "body": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["order", "text", "notes"],
                  "properties": {
                    "order": { "type": "integer", "minimum": 1 },
                    "text": { "type": "string", "minLength": 1 },
                    "notes": { "type": "string" }
                  }
                }
              },
              "cta": {
                "type": "object",
                "additionalProperties": false,
                "required": ["text", "notes"],
                "properties": {
                  "text": { "type": "string", "minLength": 1 },
                  "notes": { "type": "string" }
                }
              }
            }
          },
          "voice_and_style": {
            "type": "object",
            "additionalProperties": false,
            "required": ["persona", "tone", "language"],
            "properties": {
              "persona": { "type": "string", "minLength": 1 },
              "tone": { "type": "string", "minLength": 1 },
              "language": {
                "type": "string",
                "pattern": "^[a-z]{2}-[A-Z]{2}$"
              }
            }
          },
          "annotations": {
            "type": "object",
            "additionalProperties": false,
            "required": ["disclaimers", "sensitivity_flags"],
            "properties": {
              "disclaimers": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "sensitivity_flags": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "none",
                    "financial_claim",
                    "medical_claim",
                    "legal_claim",
                    "sensitive_topic",
                    "potential_misinformation"
                  ]
                }
              }
            }
          },
          "version": {
            "type": "string",
            "description": "Optioneel, voor iteraties (bijv. v2, alt-A)."
          }
        }
      }
    }
  },
  "$comment": "Duration-vs-word-count checks and strict body.order sequencing should be validated at runtime in addition to JSON Schema."
}
