{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/manager-orchestrator-output.schema.json",
  "title": "Manager/Orchestrator Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_state", "final_result"],
  "properties": {
    "workflow_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "created_at",
        "last_updated_at",
        "user_goal",
        "overall_status",
        "steps"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}$" },
        "last_updated_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}$" },
        "user_goal": { "type": "string", "minLength": 1 },
        "overall_status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed", "cancelled"] },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_id", "name", "agent", "status", "depends_on", "output_ref", "error"],
            "properties": {
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{2,}$" },
              "name": { "type": "string", "minLength": 1 },
              "agent": {
                "type": "string",
                "enum": [
                  "Trend_Research_Agent",
                  "Content_Planner_Agent",
                  "Script_Writer_Agent",
                  "Compliance_Quality_Agent",
                  "Visual_Asset_Agent",
                  "Video_Production_Agent",
                  "Publishing_Analytics_Agent",
                  "Manager_Orchestrator_Agent"
                ]
              },
              "status": { "type": "string", "enum": ["pending", "in_progress", "done", "failed", "skipped"] },
              "depends_on": {
                "type": "array",
                "items": { "type": "string", "pattern": "^STEP-[0-9]{2,}$" }
              },
              "output_ref": { "type": "string", "minLength": 1 },
              "error": { "type": "string" }
            }
          }
        }
      }
    },
    "final_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "summary", "artifacts", "next_actions_suggested"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trend_report",
            "content_plan",
            "scripts",
            "compliance_report",
            "visual_briefs",
            "video_production_plan",
            "publishing_plan"
          ],
          "properties": {
            "trend_report": { "type": "string" },
            "content_plan": { "type": "string" },
            "scripts": { "type": "string" },
            "compliance_report": { "type": "string" },
            "visual_briefs": { "type": "string" },
            "video_production_plan": { "type": "string" },
            "publishing_plan": { "type": "string" }
          }
        },
        "next_actions_suggested": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$comment": "Runtime checks should enforce loop prevention, retry limits, step dependency integrity, and logical consistency between workflow_state and final_result."
}
