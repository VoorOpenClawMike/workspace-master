{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/video-production-output.schema.json",
  "title": "Video Production Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan", "details"],
  "properties": {
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "project_id", "items"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "project_id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["linked_content_item_id", "script_brief_id"],
            "properties": {
              "linked_content_item_id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
              "script_brief_id": { "type": "string", "pattern": "^SB-[0-9]{3,}$" }
            }
          }
        }
      }
    },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/productionItem"
          }
        }
      }
    }
  },
  "$defs": {
    "productionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linked_content_item_id", "script_brief_id", "platform_primary", "variants"],
      "properties": {
        "linked_content_item_id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
        "script_brief_id": { "type": "string", "pattern": "^SB-[0-9]{3,}$" },
        "platform_primary": {
          "type": "string",
          "enum": ["TikTok", "YouTube Shorts", "Instagram Reels", "YouTube", "Instagram", "X", "LinkedIn"]
        },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "variant_id",
              "target_platform",
              "aspect_ratio",
              "resolution",
              "frame_rate",
              "estimated_duration_seconds",
              "render_priority",
              "audio_plan",
              "edit_timeline",
              "assets_binding",
              "thumbnail_or_cover",
              "export_settings"
            ],
            "properties": {
              "variant_id": { "type": "string", "pattern": "^VID-[0-9]{3,}-V[0-9]+$" },
              "target_platform": {
                "type": "string",
                "enum": ["TikTok", "YouTube Shorts", "Instagram Reels", "YouTube", "Instagram", "X", "LinkedIn"]
              },
              "aspect_ratio": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
              "resolution": { "type": "string", "pattern": "^[0-9]{3,5}x[0-9]{3,5}$" },
              "frame_rate": { "type": "integer", "minimum": 24, "maximum": 60 },
              "estimated_duration_seconds": { "type": "integer", "minimum": 5, "maximum": 3600 },
              "render_priority": { "type": "string", "enum": ["high", "normal", "low"] },
              "audio_plan": {
                "type": "object",
                "additionalProperties": false,
                "required": ["voiceover_source", "voice_profile", "music", "sfx"],
                "properties": {
                  "voiceover_source": { "type": "string", "enum": ["ai_generated", "recorded", "none"] },
                  "voice_profile": { "type": "string" },
                  "music": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "style", "loudness_strategy"],
                    "properties": {
                      "type": { "type": "string", "enum": ["royalty_free_library", "ai_generated", "none"] },
                      "style": { "type": "string" },
                      "loudness_strategy": { "type": "string", "enum": ["duck_under_voice", "intro_only", "constant_low"] }
                    }
                  },
                  "sfx": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "edit_timeline": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "order",
                    "time_range",
                    "source_type",
                    "source_ref",
                    "voiceover_segment",
                    "text_overlay_ref",
                    "transition_in",
                    "transition_out"
                  ],
                  "properties": {
                    "order": { "type": "integer", "minimum": 1 },
                    "time_range": { "type": "string", "pattern": "^[0-9]+-[0-9]+s$" },
                    "source_type": { "type": "string", "enum": ["shot", "still", "title_card"] },
                    "source_ref": { "type": "string", "minLength": 1 },
                    "voiceover_segment": { "type": "string", "enum": ["hook", "body", "cta", "none"] },
                    "text_overlay_ref": { "type": "string", "minLength": 1 },
                    "transition_in": { "type": "string", "enum": ["cut", "fade_in", "slide_up"] },
                    "transition_out": { "type": "string", "enum": ["cut", "jump_cut", "zoom_out"] }
                  }
                }
              },
              "assets_binding": {
                "type": "object",
                "additionalProperties": false,
                "required": ["shots_refs", "overlay_text_refs", "brand_assets_refs", "disclaimer_text_refs"],
                "properties": {
                  "shots_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                  "overlay_text_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                  "brand_assets_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                  "disclaimer_text_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
                }
              },
              "thumbnail_or_cover": {
                "type": "object",
                "additionalProperties": false,
                "required": ["use_concept_from_visual_agent", "thumbnail_id"],
                "properties": {
                  "use_concept_from_visual_agent": { "type": "boolean" },
                  "thumbnail_id": { "type": "string", "pattern": "^THUMB-VID-[0-9]{3,}-V[0-9]+$" }
                }
              },
              "export_settings": {
                "type": "object",
                "additionalProperties": false,
                "required": ["format", "codec", "audio_codec", "bitrate_mode", "target_bitrate_mbps"],
                "properties": {
                  "format": { "type": "string", "enum": ["mp4", "mov", "webm"] },
                  "codec": { "type": "string", "enum": ["h264", "h265", "vp9"] },
                  "audio_codec": { "type": "string", "enum": ["aac", "opus", "pcm"] },
                  "bitrate_mode": { "type": "string", "enum": ["VBR", "CBR"] },
                  "target_bitrate_mbps": { "type": "number", "minimum": 1, "maximum": 100 }
                }
              }
            }
          }
        }
      }
    }
  },
  "$comment": "Cross-checks for refs existence, timing continuity, and platform-specific caps require runtime validation in addition to JSON Schema."
}
