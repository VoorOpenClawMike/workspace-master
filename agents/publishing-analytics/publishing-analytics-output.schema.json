{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/publishing-analytics-output.schema.json",
  "title": "Publishing & Analytics Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["publishing", "analytics"],
  "properties": {
    "publishing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "timezone", "items"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "timezone": { "type": "string", "minLength": 1, "default": "Europe/Amsterdam" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "linked_content_item_id",
              "variant_id",
              "target_platform",
              "scheduled_datetime",
              "status",
              "post_external_id",
              "failure_reason",
              "kpi_goal",
              "notes"
            ],
            "properties": {
              "linked_content_item_id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
              "variant_id": { "type": "string", "pattern": "^VID-[0-9]{3,}-V[0-9]+$" },
              "target_platform": {
                "type": "string",
                "enum": ["TikTok", "YouTube Shorts", "Instagram Reels", "YouTube", "Instagram", "X", "LinkedIn"]
              },
              "scheduled_datetime": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}$"
              },
              "status": {
                "type": "string",
                "enum": ["scheduled", "published", "failed", "skipped"]
              },
              "post_external_id": { "type": ["string", "null"] },
              "failure_reason": { "type": "string" },
              "kpi_goal": { "type": "string", "enum": ["views", "engagement_rate", "followers", "clicks"] },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "analytics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reporting_window", "aggregation_level", "metrics", "per_post", "insights", "recommendations_for_planner"],
      "properties": {
        "reporting_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start_date", "end_date"],
          "properties": {
            "start_date": { "type": "string", "format": "date" },
            "end_date": { "type": "string", "format": "date" }
          }
        },
        "aggregation_level": { "type": "string", "enum": ["post", "day", "week", "campaign"] },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_views",
            "total_likes",
            "total_comments",
            "total_shares",
            "average_watch_time_seconds",
            "average_engagement_rate",
            "follower_delta"
          ],
          "properties": {
            "total_views": { "type": "integer", "minimum": 0 },
            "total_likes": { "type": "integer", "minimum": 0 },
            "total_comments": { "type": "integer", "minimum": 0 },
            "total_shares": { "type": "integer", "minimum": 0 },
            "average_watch_time_seconds": { "type": "number", "minimum": 0 },
            "average_engagement_rate": { "type": "number", "minimum": 0 },
            "follower_delta": { "type": "integer" }
          }
        },
        "per_post": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "linked_content_item_id",
              "variant_id",
              "target_platform",
              "post_external_id",
              "published_datetime",
              "views",
              "likes",
              "comments",
              "shares",
              "saves",
              "clicks",
              "engagement_rate",
              "average_view_duration_seconds"
            ],
            "properties": {
              "linked_content_item_id": { "type": "string", "pattern": "^VID-[0-9]{3,}$" },
              "variant_id": { "type": "string", "pattern": "^VID-[0-9]{3,}-V[0-9]+$" },
              "target_platform": {
                "type": "string",
                "enum": ["TikTok", "YouTube Shorts", "Instagram Reels", "YouTube", "Instagram", "X", "LinkedIn"]
              },
              "post_external_id": { "type": "string", "minLength": 1 },
              "published_datetime": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}$"
              },
              "views": { "type": "integer", "minimum": 0 },
              "likes": { "type": "integer", "minimum": 0 },
              "comments": { "type": "integer", "minimum": 0 },
              "shares": { "type": "integer", "minimum": 0 },
              "saves": { "type": "integer", "minimum": 0 },
              "clicks": { "type": "integer", "minimum": 0 },
              "engagement_rate": { "type": "number", "minimum": 0 },
              "average_view_duration_seconds": { "type": "number", "minimum": 0 }
            }
          }
        },
        "insights": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommendations_for_planner": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$comment": "Conditional checks (e.g., failed/skipped -> failure_reason required, published -> post_external_id required) and compliance-gate checks should be enforced at runtime."
}
