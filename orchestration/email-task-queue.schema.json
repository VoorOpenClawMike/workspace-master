{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {"type": "string"},
      "status": {"type": "string"},
      "priority": {"type": "number"},
      "team": {"type": "string", "enum": ["email"]},
      "requires_approval": {"type": "boolean", "const": true}
    },
    "required": ["requires_approval"]
  }
}
